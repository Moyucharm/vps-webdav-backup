[Unit]
Description=Weekly VPS WebDAV Backup Timer
Documentation=https://github.com/your-username/vps-webdav-backup
Requires=vps-webdav-backup.service

[Timer]
# Run every Monday at 03:00 AM
OnCalendar=Mon *-*-* 03:00:00
# Run immediately if the timer was missed (e.g., system was off)
Persistent=true
# Add random delay up to 5 minutes to avoid load spikes
RandomizedDelaySec=300

[Install]
WantedBy=timers.target